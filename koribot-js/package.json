{
    "name": "koribot-js",
    "version": "0.0.1",
    "description": "frontend utility script for Javacript inspired by jquery to manipulate DOM with built-in Object store",
    "author": "Walid C.",
    "license": "MIT",
    "types": "./index.d.ts",
    "main": "./main.js",
    "exports": {
        ".": {
            "import": "./dist/koribot-js.js",
            "types": "./index.d.ts"
        },
        "./dev": {
            "import": "./dist/koribot-js.dev.js",
            "types": "./index.d.ts"
        }
    },
    "keywords": [
        "javascript",
        "dom",
        "utility",
        "frontend",
        "jquery",
        "dom-manipulation",
        "object-store"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/koribot/koribot-js.git"
    },
    "files": [
        "dist",
        "main.js"
    ]
}
